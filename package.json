{
	"name": "free-on-the-pouch",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:server": "turbo -F server dev",
		"check": "biome check --write .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"@free-on-the-porch/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@free-on-the-porch/config": "workspace:*",
		"@types/node": "^22.13.14",
		"tsdown": "^0.22.2",
		"turbo": "^2.8.12",
		"typescript": "^6"
	},
	"packageManager": "pnpm@10.30.3"
}
